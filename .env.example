# MyAccount (MYA) test credentials — copy this file to `.env` and fill in real values.
# `.env` is gitignored so real credentials are never committed.

# Shared password for the MYA dev test accounts.
MYA_PASSWORD=

# Shared password for the DMX / AutoDM / prod / stage flow specs.
TEST_PASSWORD=

# Account with a mortgage loan — used by ALP-1877 / ALP-2019 / ALP-2020.
MYA_EMAIL_TABS=

# Account used by the API specs — ALP-1773 / ALP-1812 / ALP-2052.
MYA_EMAIL_API=

# Account used by the Okta auth spec — ALP-2010.
MYA_EMAIL_OKTA=

# Account used by the helpful-links / insurance spec — MYALogin-helpfull_Links_Insurance.
MYA_EMAIL_LINKS=

# Account with personal loans — used by the ALP-1877 personal-loan routing spec.
MYA_EMAIL_PERSONAL=

# Optional: override the DMX loan-application URL for any DMX spec at runtime.
# Each DMX spec falls back to its own in-code default when this is unset.
# LOAN_APPLICATION_URL=
# Optional: for the multi-env DMX specs, select 'dev' (default) or 'prod'.
# LOAN_APPLICATION_ENV=dev
